ectorI"] = "Sector I",&n&t&t["Object.SectorII"] = "Sector II",&n&t&t["Object.SectorIII"] = "Sector III",&n&t&t["Object.SectorN"] = "Sector N",&n&t&t["Object.Storage"] = "Storage",&n&t&t["Object.Security"] = "Security",&n&t&t["Object.Office"] = "Office",&n&t&t["Object.Central"] = "Central",&n&t&t["Object.Garage"] = "Garage",&n&t&t["Object.PipeSymbol"] = "|",&n&t&t["Object.SecurityPassword"] = "Security Server Password",&n&t&t["Object.GateControl"] = "Gate Control",&n&t&t["Object.GateController"] = "Gate Controller",&n&t&t["Object.SectorIFull"] = "Sector I: Storage",&n&t&t["Object.SectorIIFull"] = "Sector II: Security",&n&t&t["Object.SectorIIIFull"] = "Sector III: Office",&n&t&t["Object.SectorNFull"] = "Sector N: Central",&n&t&t["Object.SecurityDoor"] = "Security Door",&n&t&t["Object.Server"] = "Server",&n&t&t&n&t&t["Action.EnableExitPoint"] = "Enable Exit Point",&n&t&t["Action.Search"] = "Search",&n&t&t["Action.EscalateKeycards"] = "Escalate Keycard Permissions",&n&t&t["Action.RemindMe"] = "Remind Me",&n&t&t["Action.LureHim"] = "Lure Director to His Office",&n&t&t["Action.LureHer"] = "Lure Director to Her Office",&n&t&t["Action.Call"] = "Call",&n&t&t["Action.Open"] = "Open",&n&t&t["Action.Secure"] = "Secure",&n&t&t&n&t&t["UI.AlertTooHigh"] = "Alert level too high",&n&t&t["UI.GateAlreadyOpen"] = "Only one gate can be hacked at once",&n&t&t["UI.RequiresOverride"] = "Requires gate security override",&n&t&t["UI.AlreadySearched"] = "Already searched",&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t["UI.SecretServerRecord"] = "IRO ITEM RECORD - Liber Incantationum Adversariorum\n\nITEM ID: 1184599-305\n\nITEM DESCRIPTION: An untranslated leather-bound tome discovered on the outskirts of site CSP-4. Findings suggest that it was created during the late Gray Skies period of the Old Ages.\n\nLOCATION: This item is currently being held in IRO storage facility SD-427, located beneath the shore of Lake Simcoe in Ontario, Canada.\n\nSTATUS: Pending for transfer. For more details, consult today's TL sheet.\n\nREQUESTOR: Reputable historian Kalei Hale is currently requesting this item for the purpose of creating a translated form of this work.",&n&t&t["UI.LureDirector"] = "Lure Director",&n&t&t["UI.SuspiciousDistraction"] = "Suspicious Distraction",&n&t&t["UI.RequiresHigherPermission"] = "Requires higher permission level",&n&t&t["UI.SecurityCenterActive"] = "Unavailable: Security Center Active",&n&t&t["UI.DebugTakeOutSecurity"] = "Security center takedown",&n&t&t["UI.Nevermind"] = "Nevermind",&n&t&t["UI.TooManyAsks"] = "Unavailable: Asked Too Many Times",&n&t&t["UI.GateCurrentlyOpen"] = "Unavailable: Gate Currently Open",&n&t&t["UI.OpenStorage"] = "Open Storage",&n&t&t["UI.OpenSecurity"] = "Open Security",&n&t&t["UI.OpenOffice"] = "Open Office",&n&t&t["UI.OpenGate"] = "Open Gate",&n&t&t["UI.NoEnemyAccess"] = "Enemies do not currently have network access",&n&t&t["UI.EnemyHackedGate"] = "Enemies have hacked this gate open",&n&t&t["UI.GateControllerBusy"] = "Unavailable: Gate Controller Busy",&n&t&t["UI.GateControllerDown"] = "Unavailable: Gate Controller Down",&n&t&t["UI.SecurityServerPassword"] = "Security Server Password",&n&t&t["UI.RequiresTri1"] = "Requires Triangulation 1",&n&t&t["UI.RequiresTri2"] = "Requires Triangulation 2",&n&t&t&n&t&t["Hacking.UnlockNToI"] = "UNLOCK - Open Central-Storage Gate",&n&t&t["Hacking.UnlockNToII"] = "UNLOCK - Open Central-Security Gate",&n&t&t["Hacking.UnlockNToIII"] = "UNLOCK - Open Central-Office Gate",&n&t&t["Hacking.UnlockIToII"] = "UNLOCK - Open Storage-Security Gate",&n&t&t["Hacking.UnlockIIToIII"] = "UNLOCK - Open Security-Office Gate",&n&t&t["Hacking.UnlockGarage"] = "UNLOCK - Open Garage Gate",&n&t&t["Hacking.OverrideGates"] = "OVERRIDE - Override Gate Security",&n&t&t["Hacking.ScrapeServers"] = "SCRAPE - Scrape Server Data",&n&t&t["Hacking.SearchArtifactLocation"] = "SEARCH - Find Tome Location",&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t["Hacking.Open13"] = "SEARCH - Find Secret File",&n&t&t["Hacking.DisruptRadios"] = "DISRUPTION - Disable Sector's Dropped Radios",&n&t&t["Hacking.TamperDirector"] = "TAMPER - Lure Director to Computer",&n&t&t["Hacking.ScrambleRadios"] = "SCRAMBLE - Disable All Dropped Radios",&n&t&t["Hacking.AuthorizePermissionRaise"] = "AUTHORIZE - Raise Permission Level",&n&t&t["Hacking.LockdownTerminal"] = "LOCKDOWN - Block Enemy Access to Terminal",&n&t&t["Hacking.NetworkSweep"] = "SWEEP - Remove Enemy Network Access",&n&t&t["Hacking.IsolateServers"] = "ISOLATE - Isolated Needed Data",&n&t&t["Hacking.DirectorDistraction"] = "URGENT_MESSAGE - Call Director to Office",&n&t&t["Hacking.SearchCredentials"] = "SEARCH - Clone Credentials Stored on Device",&n&t&t["Hacking.OpenNToI"] = "Open Gate N-I",&n&t&t["Hacking.OpenNToII"] = "Open Gate N-II",&n&t&t["Hacking.OpenNToIII"] = "Open Gate N-III",&n&t&t["Hacking.OpenIToII"] = "Open Gate I-II",&n&t&t["Hacking.OpenIIToIII"] = "Open Gate II-III",&n&t&t["Hacking.OpenGarage"] = "Open Garage Gate",&n&t&t["Hacking.Override"] = "Override",&n&t&t["Hacking.GateSecurity"] = "Gate Security",&n&t&t["Hacking.Scrape"] = "Scrape",&n&t&t["Hacking.ServerData"] = "Server Data",&n&t&t["Hacking.ArtifactLocation"] = "Tome Location",&n&t&t["Hacking.Disrupt"] = "Disruption",&n&t&t["Hacking.DroppedRadios"] = "Disable Dropped Radios",&n&t&t["Hacking.Tamper"] = "Tamper",&n&t&t["Hacking.DirectorsPC"] = "Director's Computer",&n&t&t["Hacking.Scramble"] = "Scramble",&n&t&t["Hacking.Authorize"] = "Authorize",&n&t&t["Hacking.RaisePermission"] = "Raise Permission",&n&t&t["Hacking.Lockdown"] = "Lockdown",&n&t&t["Hacking.Terminal"] = "Terminal",&n&t&t["Hacking.Sweep"] = "Sweep",&n&t&t["Hacking.Network"] = "Network",&n&t&t["Hacking.Isolate"] = "Isolate",&n&t&t["Hacking.Distraction"] = "Distraction",&n&t&t["Hacking.CardCredentials"] = "Card Credentials",&n&t&t&n&t&t["Notify.RadiosInactive"] = "Dropped radios no longer active",&n&t&t["Notify.SecurityPasswordIs"] = "The security server password is",&n&t&t["Notify.InterrogationGaveSecPassword"] = "Interrogation gave the security server password",&n&t&t["Notify.GuardNoticedMissing"] = "Guard noticed missing",&n&t&t["Notify.TooManyMissing"] = "Too many guards noticed missing",&n&t&t["Notify.SuspiciousDistraction"] = "Suspicious distraction",&n&t&t["Notify.InterrogationGaveOfficeSafeCode"] = "Interrogation gave safe code",&n&t&t&n&t&t["Item.Tome"] = "Tome",&n&t&t["ItemDesc.Tome"] = "An ancient leather-bound tome from the Old Ages. A strange octagonal shape on a gold seal can be seen on its front. May contain information on dangerous procedures",&n&t&t["Item.UnobtainableKeycard"] = "???",&n&t&t["ItemDesc.UnobtainableKeycard"] = "What the... How did you... Huh??",&n&t&t["Item.ClosetKey"] = "Closet Key",&n&t&t["ItemDesc.ClosetKey"] = "Access key for storage and utility closets",&n&t&t&n&t&t["Password.Dance13"] = "Dance13",&n&t&t["Password.Clover21"] = "Clover21",&n&t&t["Password.Detective26"] = "Detective26",&n&t&t["Password.Story30"] = "Story30",&n&t&t["Password.Smile45"] = "Smile45",&n&t&t["Password.Ruler48"] = "Ruler48",&n&t&t["Password.Dragon50"] = "Dragon50",&n&t&t&n&t&t["Name.Security"] = "Security",&n&t&t["Name.Employee"] = "Employee",&n&t&t["Name.Director"] = "Director",&n&t&t&n&t&t["File.MeetingNotes"] = "MEETING NOTES\n\n- Security center keycard reader has been updated to require a security keycard\n- A log of all recent and current transfers will be kept on the security servers\n- In case the gate operator is out for the day, authorization can be granted from the security center and the director's office\n- New security server access key",&n&t&t["File.SecurityFile"] = "As of today, access to the security server terminal must be greatly restricted due to an attempt at downloading a video game onto the terminal\n\nThe culprit will be justly punished with removal from the security staff team on account of inappropriate actions\n\nAuthorized personell will soon be notified of the updated terminal password",&n&t&t["File.PasswordLog"] = "SECURITY TERMINAL ACTION HISTORY\n\n07:01:23 TERMINAL ACCESSED\n07:02:05 ROUTINE SCAN OF SERVERS\n07:06:53 TERMINAL SHUTDOWN\n11:34:42 TERMINAL ACCESSED\n11:35:36 UNAUTHORIZED FILE DOWNLOAD ATTEMPT - FILENAME: RobloxPlayerInstaller.exe\n14:45:23 LEVEL OF AUTHORIZATION NEEDED FOR GATE CONTROL TEMPORARILY RAISED\n14:47:49 1 FILE DELETED\n14:48:57 TERMINAL SHUTDOWN WITH PASSWORD UPDATE - NEW PASSWORD",&n&t&t&n&t&t["Dialogue.DirectorComputer"] = "Director, something popped up on your computer",&n&t&t["Dialogue.DirectorMessage"] = "Director, there's a message on your computer",&n&t&t["Dialogue.OpenStorage"] = "We need to move some boxes",&n&t&t["Dialogue.OpenSecurity"] = "The security center called us in",&n&t&t["Dialogue.OpenOffice"] = "The director needs us",&n&t&t["Dialogue.OpenGate"] = "Could you open one of the gates?",&n&t&t["Dialogue.HostageAskGate"] = "Go ask to open one of the gates",&n&t&t["Dialogue.HostageAskStorage"] = "Get the storage gate open",&n&t&t["Dialogue.HostageAskSecurity"] = "Get the security gate open",&n&t&t["Dialogue.HostageAskOffice"] = "Get the office gate open",&n&t&t["Dialogue.HostageRequestStorage"] = "Hey could you open the storage gate?",&n&t&t["Dialogue.HostageRequestSecurity"] = "Hey could you open the security gate?",&n&t&t["Dialogue.HostageRequestOffice"] = "Hey could you open the office gate?",&n&t&t["Dialogue.GovtInspection"] = "I'm here for an inspection",&n&t&t&n&t&t["Speaker.Hoax"] = "Hoax",&n&t&t&n&t&t&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.Intro1"] = "You're still certain you want to do this?",&n&t&t["Operator.Any.Intro1"] = "I'll be fine|\nThe sooner we can get this operation done, the better",&n&t&t&n&t&t["Hoax.Intro2"] = "Our medics say you won't be ready for operations\nuntil a few weeks from now",&n&t&t["Operator.Any.Intro2"] = "The injuries weren't that bad|\nI'm sure they were overestimating recovery time",&n&t&t&n&t&t["Hoax.Intro3"] = "Alright, again, you're positive that you\nweren't hurt that bad by that fall?",&n&t&t["Operator.Any.Intro3"] = "Absolutely. This mission is too important to just let go",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.GatesCompromised"] = "We've compromised their gate control system",&n&t&t["Hoax.GatesCompromised"] = "Okay, now on to the next stage of the operation",&n&t&t&n&t&t["Operator.Any.GatesCompromisedNoTablet"] = "We have access to their gate control system,\nbut we don't have a tablet to operate",&n&t&t["Hoax.GatesCompromisedNoTablet"] = "Bit of a last-ditch effort, but there might be\none somewhere in storage or a closet",&n&t&t&n&t&t["Hoax.PermissionLevel"] = "Seems like you'll need a higher access level to open some gates|\nTry looking around the sectors for ways to raise your permission level",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.LocationFound"] = "Found which truck the tome's being kept in",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.FailedArtifactSearch1"] = "Nope...",&n&t&t&n&t&t["Operator.Any.FailedArtifactSearch2"] = "Not in this one...",&n&t&t&n&t&t["Operator.Any.FailedArtifactSearch3"] = "Not here...",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.UselessSearch1"] = "Nope...",&n&t&t&n&t&t["Operator.Any.UselessSearch2"] = "Useless...",&n&t&t&n&t&t["Operator.Any.UselessSearch3"] = "Nothing good...",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.ArtifactFound"] = "I think I found the tome we're looking for here|\nLiber... Incant... something, right?",&n&t&t["Hoax.ArtifactFound"] = "Yep, that's the one|\nIt might not be as flashy as a sword, but it may be\nof equal importance to the Adversarialists",&n&t&t&n&t&t["Hoax.ArtifactFoundNeedServers"] = "Now you just need to get the data and we'll be good to go",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.ServersAccessed"] = "In the server room",&n&t&t["Hoax.ServersAccessed"] = "Good, now you have two options|\nYou can scrape the servers and get the data directly,\nor you can isolate what we need to one server and take it",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.ServersScraped"] = "Servers have been scraped",&n&t&t["Hoax.ServersScraped"] = "Alright, I can see the data coming through now|\nThis could prove to be very useful for the future",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.ServersIsolated"] = "Data has been isolated",&n&t&t["Hoax.ServersIsolated"] = "Remember that you need to secure the server at an\nexit point before you can get out of there",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.ServersScrapedNeedArtifact"] = "Now you just need to find that tome and we'll be good to go",&n&t&t["Hoax.ServersScrapedFoundInfo"] = "There's an archive lookup code here for some kind of document\nthat has the location of the tome, I'll send it to you now",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.PowerBoxQuestion"] = "Hey Hoax, any idea what this power box could be for?",&n&t&t["Hoax.PowerBoxQuestion1"] = "From what I've gathered, it could possibly be\ntied to a permission check system",&n&t&t["Hoax.PowerBoxQuestion2"] = "Killing power to all boxes in the area could reduce\nits strength and give you greater access",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.CanExfiltrateStealth"] = "That should be all, now|\nGet back to wherever you came from and get out of there",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.OfficeBluff"] = "I'm here to inspect the office area of the facility|\nGovernment regulation, you know?",&n&t&t["Dialogue.OfficeBluff"] = "I see. The schedule must have changed since I last checked, then|\nGo ahead",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.OpenGate"] = "Hey, could you open one of the gates for us?",&n&t&t&n&t&t["Operator.Any.OpenStorage"] = "We need the gate to storage open|\nWe're going to be moving some boxes soon",&n&t&t&n&t&t["Operator.Any.OpenSecurity"] = "We need the gate to security open|\nThe security center called us in for a private meeting",&n&t&t&n&t&t["Operator.Any.OpenOffice"] = "We need the gate to the office open|\nThe director needs us for something",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.HostageOpenGate"] = "Go ask the gate controller to open one of the gates",&n&t&t&n&t&t["Operator.Any.HostageOpenStorage"] = "Go ask the gate controller to open one of the gates|\nWe'll need the gate to the storage sector open",&n&n&t&t["Operator.Any.HostageOpenSecurity"] = "Go ask the gate controller to open one of the gates|\nWe'll need the gate to the security sector open",&n&n&t&t["Operator.Any.HostageOpenOffice"] = "Go ask the gate controller to open one of the gates|\nWe'll need the gate to the office sector open",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.DirectorLure"] = "Director, we're seeing something come up on your computer|\nYou might want to have a look in your office",&n&t&t&n&t&t["Operator.Any.DirectorLureNotSuspicious"] = "Director, we got a notification that there's a message on your office computer|\nSomething urgent about a request for an untranslated tome",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.TakedownFirstWarning"] = "Be careful with taking out guards. The security center and\nthe director will probably get suspicious if you do",&n&t&t&n&t&t["Hoax.TakedownSecondWarning"] = "The more guards they notice missing,\nthe faster and more seriously they're gonna take it",&n&t&t&n&t&t["Hoax.TakedownFinalWarning"] = "They're definitely going to raise the alarm with all the missing guards now|\nGet done quick or take care of the director and security center",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.TakedownStop"] = "Security center and director have been taken care of",&n&t&t["Hoax.TakedownStop"] = "Good, just remember that radios are still an issue",&n&t&t&n&t&t&n&t&t&n&t&t["Operator.Any.JunctionExamined1"] = "Looks like this junction box is tied to the\nfacility's keycard readers",&n&t&t["Operator.Any.JunctionExamined2"] = "If I can rewire it, I might be able to\nlower the restrictions on the readers",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.LoudStart1"] = "Police scanners are going off and TRU is being called in,\neverything okay in there?",&n&t&t["Operator.Any.LoudStart1"] = "Perfectly fine, everything's under control",&n&t&t&n&t&t["Hoax.LoudStart2"] = "Radio activity just spiked, looks like they're calling in TRU",&n&t&t["Operator.Any.LoudStart2"] = "We can handle them, don't worry",&n&t&t&n&t&t["Hoax.LoudStart3"] = "I'm seeing police activity in the area, and TRU is headed your way",&n&t&t["Operator.Any.LoudStart3"] = "Nothing we haven't dealt with before, we've got this",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.TRUArrive"] = "TRU is here, and it looks like they're in for the long haul|\nGet ready",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.TRUAccessedGates"] = "Enemy units have accessed the gate controls|\nWatch your back",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.TRUFirstAegis"] = "TRU is sending in an Aegis unit to your location|\nBe careful",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.GetToCenter"] = "Now take the tome and get to the central chamber|\nIt's time for you to get out of there",&n&t&t&n&t&t["Hoax.GetToCenterStandalone"] = "Alright, get ready for exfiltration and go to the central room\n|You're taking the explosive way out",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.DetonationReady"] = "Alright, stand clear of the detonation site and be ready to\nmake a break for it once you've cleared out the enemy units",&n&t&t&n&t&t&n&t&t&n&t&t["Hoax.BridgeAegis"] = "Look out, they've got a squad with an Aegis coming in|\nThey're trying to flank you before you can escape",&n&t},&n&t&n&tDialogue = {&n&t&tMissionEnter = {&n&t&t&t{"Hoax.Intro1", "Operator.Any.Intro1"},&n&t&t&t{"Hoax.Intro2", "Operator.Any.Intro2"},&n&t&t&t{"Hoax.Intro3", "Operator.Any.Intro3"}&n&t&t},&n&t&t&n&t&tGatesCompromised = {&n&t&t&t{"Operator.Any.GatesCompromised", "Hoax.GatesCompromised", "Hoax.PermissionLevel"}&n&t&t},&n&t&t&n&t&tGatesCompromisedNoTablet = {&n&t&t&t{"Operator.Any.GatesCompromisedNoTablet", "Hoax.GatesCompromisedNoTablet", "Hoax.PermissionLevel"}&n&t&t},&n&t&t&n&t&tLocationFound = {&n&t&t&t{"Operator.Any.LocationFound"}&n&t&t},&n&t&t&n&t&tFailedArtifactSearch = {&n&t&t&t{"Operator.Any.FailedArtifactSearch1"},&n&t&t&t{"Operator.Any.FailedArtifactSearch2"},&n&t&t&t{"Operator.Any.FailedArtifactSearch3"},&n&t&t},&n&t&t&n&t&tArtifactFoundServers = {&n&t&t&t{"Operator.Any.ArtifactFound", "Hoax.ArtifactFound", "Hoax.CanExfiltrateStealth"}&n&t&t},&n&t&t&n&t&tArtifactFoundServersLoud = {&n&t&t&t{"Operator.Any.ArtifactFound", "Hoax.ArtifactFound", "Hoax.GetToCenter"}&n&t&t},&n&t&t&n&t&tArtifactFoundNoServers = {&n&t&t&t{"Operator.Any.ArtifactFound", "Hoax.ArtifactFound", "Hoax.ArtifactFoundNeedServers"}&n&t&t},&n&t&t&n&t&tServersAccessed = {&n&t&t&t{"Operator.Any.ServersAccessed", "Hoax.ServersAccessed"}&n&t&t},&n&t&t&n&t&tServersScrapedNoInfoFound = {&n&t&t&t{"Operator.Any.ServersScraped", "Hoax.ServersScraped", "Hoax.ServersScrapedNeedArtifact"}&n&t&t},&n&t&t&n&t&tServersScrapedInfoFound = {&n&t&t&t{"Operator.Any.ServersScraped", "Hoax.ServersScraped", "Hoax.ServersScrapedFoundInfo"}&n&t&t},&n&t&t&n&t&tServersIsolatedNoArtifact = {&n&t&t&t{"Operator.Any.ServersIsolated", "Hoax.ServersIsolated", "Hoax.ServersScrapedNeedArtifact"}&n&t&t},&n&t&t&n&t&tServersScrapedArtifact = {&n&t&t&t{"Operator.Any.ServersScraped", "Hoax.ServersScraped", "Hoax.CanExfiltrateStealth"}&n&t&t},&n&t&t&n&t&tServersIsolatedArtifact = {&n&t&t&t{"Operator.Any.ServersIsolated", "Hoax.ServersIsolated", "Hoax.CanExfiltrateStealth"}&n&t&t},&n&t&t&n&t&tServersScrapedArtifactLoud = {&n&t&t&t{"Operator.Any.ServersScraped", "Hoax.ServersScraped", "Hoax.GetToCenter"}&n&t&t},&n&t&t&n&t&tTakedownFirstWarning = {&n&t&t&t{"Hoax.TakedownFirstWarning"}&n&t&t},&n&t&t&n&t&tTakedownSecondWarning = {&n&t&t&t{"Hoax.TakedownSecondWarning"}&n&t&t},&n&t&t&n&t&t