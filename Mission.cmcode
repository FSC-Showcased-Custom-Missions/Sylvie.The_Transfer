f",&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferSectorNOpen",&n&t&t&tIndent = 1,&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferCombat",&n&t&t&tIndent = 0,&n&t&t&tTags = { "Tag.Combat" },&n&t&t&tHighlightTags = true,&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferEnemyAccess",&n&t&t&tIndent = 1,&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferEnemyTerminal",&n&t&t&tIndent = 2,&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferTerminalLock",&n&t&t&tIndent = 3,&n&t&t&tTags = { "Tag.Hacking" },&n&t&t&tUnlock = "TransferTerminalLock",&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferNetworkSweep",&n&t&t&tIndent = 3,&n&t&t&tTags = { "Tag.Hacking" },&n&t&t&tUnlock = "TransferNetworkSweep",&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferEnemySwitch",&n&t&t&tIndent = 2,&n&t&t&tTags = { "Tag.OperativePlus" },&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferDisableSwitch",&n&t&t&tIndent = 3,&n&t&t&tUnlock = "TransferDisableSwitch",&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferMidGates",&n&t&t&tIndent = 2,&n&t&t&tUnlock = "TransferMidGates",&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferEndGates",&n&t&t&tIndent = 2,&n&t&t&tUnlock = "TransferEndGates",&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferIsolatedGates",&n&t&t&tIndent = 2,&n&t&t&tUnlock = "TransferIsolatedGates",&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferUnitBoost",&n&t&t&tIndent = 2,&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferMidAegis",&n&t&t&tIndent = 1,&n&t&t&tTags = { "Tag.Recruit", "Tag.Operative" },&n&t&t&tUnlock = "TransferMidAegis",&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferSewerTunnel",&n&t&t&tIndent = 1,&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferDetonation",&n&t&t&tIndent = 2,&n&t&t},&n&t&t{&n&t&t&tText = "Intel.TransferEndAegis",&n&t&t&tIndent = 2,&n&t&t&tTags = { "Tag.Legend" },&n&t&t&tUnlock = "TransferEndAegis",&n&t&t},&n&t},&n&t&n&tCustomStrings = {&n&t&t["MissionTitle.TheTransfer"] = "The Transfer",&n&t&t["MissionDescription.TheTransfer"] = "Alright... I'm still not sure you're ready for this yet, but it's your choice. Today, you'll be infiltrating an IRO facility located under the shore of Lake Simcoe. Your primary target is a tome from the Old Ages that has been determined to be slated for transfer. The requestor of the tome is someone working for the Adversarialists, and if the Adversarialists were to get their hands on it, it would give them a major boost in their endeavors, so we can't let that happen. We have decent intel on security protocols and facility functions, but that's about it. Some remote explosives have been planted in a sewer adjacent to the facility in case things end in a firefight. Finally, if you weren't going to already, I would suggest that you bring a hacking tablet to this one. Good luck in there.",&n&t&t["StartingLocationTitle.EntryPoint"] = "Entry Point",&n&t&t&n&t&t["StartingLocation.TransferVentilationShaft"] = "Ventilation Shaft",&n&t&t["StartingLocation.TransferVentilationShaft.Desc"] = "Rope down a ventilation shaft and bust through a vent in the storage sector",&n&t&t["StartingLocation.TransferBackEntrance"] = "Back Entrance",&n&t&t["StartingLocation.TransferBackEntrance.Desc"] = "Sneak down a back tunnel and enter through a fire escape in the security sector",&n&t&t["StartingLocation.TransferFrontEntrance"] = "Front Entrance",&n&t&t["StartingLocation.TransferFrontEntrance.Desc"] = "Pose as a government worker to make it through the front gate into the office sector",&n&t&t&n&t&t["Tooltip.RequiresSkillElectricalEngineer2"] = "Requires Skill: Electrical Engineering 2",&n&t&t&n&t&t["Intel.TransferStealStuff"] = "Steal server data and a tome from a government storage and research facility",&n&t&t["Intel.TransferSectorDivide"] = "The facility is divided into sectors separated by gates",&n&t&t["Intel.TransferSectorNames"] = "Sector N is the central room, Sector I is storage, Sector II is security, and Sector III is the office space",&n&t&t["Intel.TransferCentralControl"] = "Gates can be opened through controls on the terminal in the central room",&n&t&t["Intel.TransferNetworkSwitches"] = "Gates can also be opened through the facility's network switches",&n&t&t["Intel.TransferPermissionLevel"] = "Access to the facility's gate controls relies on a permission level system",&n&t&t["Intel.TransferStorageBoxes"] = "Killing all power boxes in Sector I will raise the permission level",&n&t&t["Intel.TransferDirectorAuthorize"] = "A permission raise can be authorized from the director's computer",&n&t&t["Intel.TransferSecurityAuthorize"] = "A permission raise can be authorized from the security center terminal",&n&t&t["Intel.TransferServersLocked"] = "Access to the servers is locked behind a security keycard reader and a USB key",&n&t&t["Intel.TransferStorageUsb"] = "A USB key can be found in a network switch closet",&n&t&t["Intel.TransferSafeUsb"] = "A USB key can be found in a safe in the security center",&n&t&t["Intel.TransferTomeTruck"] = "The tome is located in a truck in the garage of Sector I",&n&t&t["Intel.TransferGaragePermission"] = "The garage gate can be opened with two permission level raises",&n&t&t["Intel.TransferGarageReader"] = "The garage can be accessed through a high-security card reader",&n&t&t["Intel.TransferGarageEscalate"] = "Keycard permissions must be escalated to use the reader",&n&t&t["Intel.TransferSafeCard"] = "A high security keycard can be found in a safe in the director's office",&n&t&t["Intel.TransferDirectorInterrogate"] = "The director can be interrogated for the safe code",&n&t&t["Intel.TransferUnknownLocation"] = "Which truck the tome is located in is unknown",&n&t&t["Intel.TransferArchives"] = "The correct truck can be identified by searching the archives",&n&t&t["Intel.TransferSecuritySearch"] = "The correct truck can be identified by hacking the security center terminal",&n&t&t&n&t&t["Intel.TransferSecurityTeam"] = "A professional security team is present on-site",&n&t&t["Intel.TransferNoticeMissing"] = "The director and security center will notice individual missing guards if they are not taken care of",&n&t&t["Intel.TransferDirectorRoam"] = "The director roams the office area and halls of Sector III",&n&t&t["Intel.TransferComputerLure"] = "The director can be lured to their office if a message is planted on their computer",&n&t&t["Intel.TransferRadioLure"] = "The director can be lured to their office if notified on the radio",&n&t&t["Intel.TransferSecurityCenter"] = "A security center in Sector II watches over the cameras",&n&t&t["Intel.TransferGarageCams"] = "Cameras in the garage are monitored remotely",&n&t&t["Intel.TransferEscalatePanel"] = "A junction box near the security center can be rewired to escalate keycard permissions",&n&t&t["Intel.TransferLockerRoom"] = "A locker room with a clothing basket can be found in Sector II",&n&t&t["Intel.TransferRadioDisrupt"] = "Worn radios can be disrupted through the facility's access points",&n&t&t&n&t&t["Intel.TransferEntryPoint"] = "The facility can be entered through any of the three outer sectors",&n&t&t["Intel.TransferVentEntry"] = "Sector I can be entered through an air vent",&n&t&t["Intel.TransferOpenExit"] = "Entering this way opens up an additional exit point",&n&t&t["Intel.TransferVentEntrySaw"] = "This exit point can also be opened up by sawing the air vent open",&n&t&t["Intel.TransferBackEntry"] = "Sector II can be entered through a fire escape",&n&t&t["Intel.TransferBackEntryRewire"] = "This exit point can also be opened up by rewiring the door alarm",&n&t&t["Intel.TransferFrontEntry"] = "Sector III can be entered through the front entrance",&n&t&t["Intel.TransferFrontExit"] = "The front entrance can also be used as an exit",&n&t&t["Intel.TransferOfficeBluff"] = "The office area of Sector III can be bluffed through",&n&t&t["Intel.TransferSectorNOpen"] = "A gate leading to Sector N will be open from one of the sectors entered through",&n&t&t&n&t&t["Intel.TransferCombat"] = "You may want to be aware of some things before entering combat in this mission",&n&t&t["Intel.TransferEnemyAccess"] = "Enemy units may be able to access and utilize the facility's gate system",&n&t&t["Intel.TransferEnemyTerminal"] = "Enemy units can access the system through the gate control terminal",&n&t&t["Intel.TransferTerminalLock"] = "This can be prevented by locking down the terminal",&n&t&t["Intel.TransferNetworkSweep"] = "Enemy access to the network can also be removed from the terminal",&n&t&t["Intel.TransferEnemySwitch"] = "Enemy units can also access the system through the facility's network switches",&n&t&t["Intel.TransferDisableSwitch"] = "Disabling a network switch stops enemies from accessing it",&n&t&t["Intel.TransferMidGates"] = "Enemies will open the gates between the outer sectors if half of our objective is complete",&n&t&t["Intel.TransferEndGates"] = "Enemies will open the gates leading to Sector N if we try to exfiltrate",&n&t&t["Intel.TransferIsolatedGates"] = "If no gates in your sector are open, enemies will try to open one of them",&n&t&t["Intel.TransferUnitBoost"] = "The more ways enemies have of accessing you, the more units they will bring in at once",&n&t&t["Intel.TransferMidAegis"] = "Enemies will send in an Aegis unit after half of our objective is complete",&n&t&t["Intel.TransferSewerTunnel"] = "You will exfiltrate through a sewer tunnel that shares a wall with the facility",&n&t&t["Intel.TransferDetonation"] = "Remote explosives will breach the wall between Sector N's back hall and the sewer",&n&t&t["Intel.TransferEndAegis"] = "A squad with an Aegis unit will try to flank us after the detonation",&n&t&t&n&t&t["Hint.TransferNetworkSwitches"] = "Hack a network switch",&n&t&t["Hint.TransferDirectorAuthorize"] = "Hack the director's computer",&n&t&t["Hint.TransferSecurityAuthorize"] = "Hack the security center terminal",&n&t&t["Hint.TransferSafeUsb"] = "Open the safe in the security center",&n&t&t["Hint.TransferSafeCard"] = "[Safecracking] Open the safe in the director's office",&n&t&t["Hint.TransferDirectorInterrogate"] = "[Intimidation] Take the director hostage",&n&t&t["Hint.TransferGarageReader"] = "Access the garage through the keycard door",&n&t&t["Hint.TransferGarageEscalate"] = "[Legend] Rewire the circuit box and access the garage through the keycard door",&n&t&t["Hint.TransferArchives"] = "[Operative+] Search the archives",&n&t&t["Hint.TransferSecuritySearch"] = "[Operative+] Search the security center terminal",&n&t&t["Hint.TransferComputerLure"] = "Hack the director's computer",&n&t&t["Hint.TransferRadioLure"] = "Make a distraction using a radio",&n&t&t["Hint.TransferEscalatePanel"] = "[Electrical Engineering] Rewire the circuit box outside the security center",&n&t&t["Hint.TransferLockerRoom"] = "Look in the locked rooms in Sector II",&n&t&t["Hint.TransferRadioDisrupt"] = "Hack an access point",&n&t&t["Hint.TransferVentEntrySaw"] = "[Saw] Investigate the vent entrance without using it as an entry point",&n&t&t["Hint.TransferBackEntryRewire"] = "[Electrical Engineering] Investigate the back entrance without using it as an entry point",&n&t&t["Hint.TransferOfficeBluff"] = "[Social Engineering] Get caught trespassing in the office area",&n&t&t["Hint.TransferTerminalLock"] = "[Hacking] Hack the gate control terminal in combat",&n&t&t["Hint.TransferNetworkSweep"] = "[Hacking] Hack the gate control terminal in combat",&n&t&t["Hint.TransferDisableSwitch"] = "[Operative+] Disable a network switch in combat",&n&t&t["Hint.TransferMidGates"] = "Complete half of our objective in combat with enemies having gate control access",&n&t&t["Hint.TransferEndGates"] = "Complete the mission objective in combat with enemies having gate control access",&n&t&t["Hint.TransferIsolatedGates"] = "Be in a sector with no open gates in combat with enemies having gate control access",&n&t&t["Hint.TransferMidAegis"] = "[Recruit, Operative] Complete half of our objective in combat",&n&t&t["Hint.TransferEndAegis"] = "[Legend] Make it to exfiltration in combat",&n&t&t&n&t&t["Tag.MainObjective"] = "Main Objective",&n&t&t["Tag.Hacking"] = 