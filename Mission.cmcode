= 0 &&&& SecurityPasswordSearch0 || SecurityPasswordValidSearch == 1 &&&& SecurityPasswordSearch1 || SecurityPasswordValidSearch == 2 &&&& SecurityPasswordSearch2",&n&t&tSecurityPasswordFailedSearches = "(SecurityPasswordValidSearch ~= 0 &&&& SecurityPasswordSearch0) + (SecurityPasswordValidSearch ~= 1 &&&& SecurityPasswordSearch1) + (SecurityPasswordValidSearch ~= 2 &&&& SecurityPasswordSearch2)",&n&t&tSecurityPasswordFound = "SecurityPasswordInterrogation || SecurityPasswordSuccessfulSearch",&n&t&t&n&t&tHowsDirectorFeelingToday = "DirectorRandom - 1", -- See comment on DirectorRandom in InternalHash&n&n&t&tStorageBox1Global = "StorageBox1",&n&t&tStorageBox2Global = "StorageBox2",&n&t&tStorageBoxKilled = "Mission_Difficulty <= 1 &&&& StorageBox1 >= 1 || StorageBox1 >= 1 &&&& StorageBox2 >= 1",&n&t&tPermissionLevel = "StorageBoxKilled + GateOverride + SecurityCenterOverride",&n&t&tGaragePermission = "2 + Variant_HigherPermission",&n&t&t&n&t&tGateControlEntered = "GateControlEntered || PlayersInGateControl",&n&t&t&n&t&tServerMinimumCard = "!Variant_ElevatedGarageCard &&&& (Escalation &&&& [BasicKeycard] || [SecurityKeycard]) || (Escalation &&&& [SecurityKeycard] || [HighSecurityKeycard])",&n&t&tServerValidCards = "!Variant_ElevatedGarageCard &&&& (Escalation &&&& [BasicKeycard SecurityKeycard HighSecurityKeycard] || [SecurityKeycard HighSecurityKeycard]) || (Escalation &&&& [SecurityKeycard HighSecurityKeycard] || [HighSecurityKeycard])",&n&t&t&n&t&tGarageMinimumCard = "!Variant_ElevatedGarageCard &&&& Mission_Difficulty < 3 &&&& (Escalation &&&& [SecurityKeycard] || [HighSecurityKeycard]) || (Escalation &&&& [HighSecurityKeycard] || [UnobtainableKeycard])",&n&t&tGarageValidCards = "!Variant_ElevatedGarageCard &&&& Mission_Difficulty < 3 &&&& (Escalation &&&& [SecurityKeycard HighSecurityKeycard] || [HighSecurityKeycard]) || (Escalation &&&& [HighSecurityKeycard] || [])",&n&t&t&n&t&tUsbKeySpawn = "UsbKeySpawnId - 1",&n&t&tUsbKeyEverHeld = "UsbKeyEverHeld || SecurityKeyHeld",&n&t&t&n&t&tTotalAsks = "0",&n&t&tRequestedN1Open = "0",&n&t&tRequestedN2Open = "0",&n&t&tRequestedN3Open = "0",&n&t&tPlayersIn1Delayed = "0",&n&t&tPlayersIn2Delayed = "0",&n&t&tPlayersIn3Delayed = "0",&n&t&tPlayersInNDelayed = "0",&n&t&tSecurityPasswordInterrogation = "0",&n&t&t&n&t&tPlayersInGarage = "PlayersInGarage1 + PlayersInGarage2 + PlayersInGarage3",&n&t&tGarageEntered = "PlayersInGarage || (GarageOpen || GarageEntranceOpen) &&&& PlayersOutsideGarage &&&& Mission_AlarmRaised",&n&t&t&n&t&tPlayersInCentral = "PlayersInCentral1 + PlayersInCentral2 + PlayersInCentral3",&n&n&t&tIs12Open = "12Open || Requested12Open || EnemyOpen12Delayed",&n&t&tIs23Open = "23Open || Requested23Open || EnemyOpen23Delayed",&n&t&tIsN1Open = "N1Open || RequestedN1Open || EnemyOpenN1Delayed",&n&t&tIsN2Open = "N2Open || RequestedN2Open || EnemyOpenN2Delayed",&n&t&tIsN3Open = "N3Open || RequestedN3Open || EnemyOpenN3Delayed",&n&t&tIsGarageOpen = "GarageOpen || RequestedGarageOpen || EnemyOpenGarageDelayed",&n&t&t&n&t&tUsedHostageBluff = "UsedHostageStorage || UsedHostageSecurity || UsedHostageOffice", -- scrapped&n&t&t&n&t&tCredentialWriterBrought = "CredentialWriterBrought || CredentialWriterHeld",&n&t&t&n&t&tSector1ClosetUnlock = "StartOpen1 || StartOpen3 &&&& UsbKeySpawn",&n&t&tSector2ClosetUnlock = "StartOpen2 || StartOpen3 &&&& !UsbKeySpawn",&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&t&tDisruptSequenceFailed = "DisruptSequenceFailed || EverDisruptedN &&&& !EverDisrupted3 || EverDisrupted2 &&&& !EverDisruptedN || EverDisrupted1 &&&& !EverDisrupted2", Enable13 = "EverDisrupted1 &&&& EverDisrupted2 &&&& EverDisrupted3 &&&& EverDisruptedN &&&& !DisruptSequenceFailed",&n&t&t&n&t&t-- Combat stuff starts here&n&t&t&n&t&t-- Start TRU assault and determine total wave count&n&t&tAssaultStarted = "Mission_AlarmRaised &&&& AssaultStartTimer <= 0",&n&t&tCombatWaves = "MainWaveNumber + (GarageWaveNumber - 1) * 0.5 + (SewerWaveNumber - 1) * 0.5",&n&t&t-- Determine which sector gates enemies have access to&n&t&tEnemyGatesCompromised1 = "EnemyGatesCompromisedMain || (EnemyGatesCompromisedNS1 &&&& !NS1Disabled)",&n&t&tEnemyGatesCompromised2 = "EnemyGatesCompromisedMain || (EnemyGatesCompromisedNS2 &&&& !NS2Disabled)",&n&t&tEnemyGatesCompromised3 = "EnemyGatesCompromisedMain || (EnemyGatesCompromisedNS3 &&&& !NS3Disabled)",&n&t&tEnemyGatesCompromised = "EnemyGatesCompromisedMain || (EnemyGatesCompromisedNS1 &&&& !NS1Disabled) || (EnemyGatesCompromisedNS2 &&&& !NS2Disabled) || (EnemyGatesCompromisedNS3 &&&& !NS3Disabled)",&n&t&t-- Determine which sectors can be accessed from which other sectors&n&t&tCan1Access2 = "Is12Open || IsN1Open &&&& IsN2Open",&n&t&tCan2Access3 = "Is23Open || IsN2Open &&&& IsN3Open",&n&t&tCan1Access3 = "IsN1Open &&&& IsN3Open || Is12Open &&&& (Is23Open || IsN2Open &&&& IsN3Open) || Is23Open &&&& IsN2Open &&&& IsN1Open",&n&t&tCanNAccess1 = "IsN1Open || Is12Open &&&& IsN2Open || Is12Open &&&& Is23Open &&&& IsN3Open",&n&t&tCanNAccess2 = "IsN2Open || Is12Open &&&& IsN2Open || Is23Open &&&& IsN3Open",&n&t&tCanNAccess3 = "IsN3Open || Is23Open &&&& IsN2Open || Is23Open &&&& Is12Open &&&& IsN1Open",&n&t&t-- Determine if sectors are completely inaccessible&n&t&tInaccessible1 = "!Can1Access2 &&&& !Can1Access3 &&&& !CanNAccess1",&n&t&tInaccessible2 = "!Can1Access2 &&&& !Can2Access3 &&&& !CanNAccess2",&n&t&tInaccessible3 = "!Can1Access3 &&&& !Can2Access3 &&&& !CanNAccess3",&n&t&t-- I wish there was a way to detect players based on cell tags&n&t&tPlayersIn1 = "PlayersInGarage + PlayersOutsideGarage + PlayersInStorage1 + PlayersInStorage2 + PlayersInStorage3 + PlayersInStorage4 + PlayersInStorage5 + PlayersInStorage6 + PlayersInStorage7 + PlayersInStorageCloset1 + PlayersInStorageCloset2 + PlayersInNS1Closet",&n&t&tPlayersIn2 = "PlayersInLockerRoom + PlayersInSecurityCenter + PlayersInSecurity1 + PlayersInSecurity2 + PlayersInSecurity3 + PlayersInSecurity4 + PlayersInSecurity5 + PlayersInSecurity6 + PlayersInSecurity7 + PlayersInSecurity8 + PlayersInSecurity9 + PlayersInSecurityCloset1 + PlayersInSecurityCloset2",&n&t&tPlayersIn3 = "PlayersInServerRoom + PlayersInDirectorOffice + PlayersInArchives + PlayersInOffice1 + PlayersInOffice2 + PlayersInOffice3 + PlayersInOffice4 + PlayersInOffice5 + PlayersInOffice6 + PlayersInOffice7",&n&t&tPlayersInN = "PlayersInCentral + PlayersInCentral4 + PlayersInSewer1 + PlayersInSewer2",&n&t&t-- Determine which sectors enemies can spawn in depending on if players can be accessed from those sectors, or if there's an uncompromised network switch in that sector&n&t&tSectorIEnemySpawns = "PlayersIn1Delayed || PlayersIn2Delayed &&&& Is12Open || PlayersIn3Delayed &&&& IsN1Open &&&& IsN3Open || PlayersInNDelayed &&&& IsN1Open",&n&t&tSectorIIEnemySpawns = "PlayersIn2Delayed || PlayersIn1Delayed &&&& Is12Open || PlayersIn3Delayed &&&& Is23Open || PlayersInNDelayed &&&& IsN2Open",&n&t&tSectorIIIEnemySpawns = "PlayersIn3Delayed || PlayersIn2Delayed &&&& Is23Open || PlayersIn1Delayed &&&& IsN1Open &&&& IsN3Open || PlayersInNDelayed &&&& IsN3Open",&n&t&tSectorNEnemySpawns = "PlayersInNDelayed || PlayersIn1Delayed &&&& IsN1Open || PlayersIn2Delayed &&&& IsN2Open || PlayersIn3Delayed &&&& IsN3Open",&n&t&t-- Trigger enemy gate opening&n&t&tEnemyOpen12 = "(EnemyGatesCompromised1 || EnemyGatesCompromised2) &&&& (ServersScraped || ServersIsolated || ArtifactSearch5)",&n&t&tEnemyOpen23 = "(EnemyGatesCompromised2 || EnemyGatesCompromised3) &&&& (ServersScraped || ServersIsolated || ArtifactSearch5)",&n&t&tEnemyOpenGarage = "EnemyGatesCompromised1 &&&& (GarageEntered || ExfiltrationDetonate) &&&& !GarageOpen",&n&t&tEnemyOpenN1 = "EnemyGatesCompromised1 &&&& (EnemyOpenN1 || BlastTimer <= 10 || PlayersIn1 &&&& Inaccessible1)",&n&t&tEnemyOpenN2 = "EnemyGatesCompromised2 &&&& (EnemyOpenN2 || BlastTimer <= 10 || PlayersIn2 &&&& Inaccessible2)",&n&t&tEnemyOpenN3 = "EnemyGatesCompromised3 &&&& (EnemyOpenN3 || BlastTimer <= 10 || PlayersIn3 &&&& Inaccessible3)",&n&t&t-- Give a boost to the main wave spawn cap the more sectors enemies can spawn in; serves to punish not caring about enemies accessing gates as well as make spreading out in multiplayer more difficult&n&t&tEnemySectorCountBoost = "SectorIEnemySpawns + SectorIIEnemySpawns + SectorIIIEnemySpawns + SectorNEnemySpawns",&n&t&t-- Relax main wave maximum unit counts&n&t&tRelaxMainWave = "ExfiltrationDetonate || GarageEntered &&&& (PlayersInGarage + PlayersOutsideGarage - PlayersInGarage3) >= (Mission_PlayersInGame == 1 &&&& 1 || (Mission_PlayersInGame == 2 || Mission_PlayersInGame == 3) &&&& 2 || Mission_PlayersInGame - 1) &&&& UnrelaxTimer",&n&t&t-- Recruit && Operative Aegis spawn&n&t&tStartAegisSpawn = "StartAegisSpawn || Mission_Difficulty < 3 &&&& AssaultStarted &&&& (ServersScraped || ServersIsolated || ArtifactSearch5)",&n&t&tSpawnAegis = "StealthExitBlocked &&&& !AegisSpawnDelay &&&& Mission_Difficulty < 3",&n&t&t-- Start detonation escape sequence&n&t&tStartDetonation = "StartDetonation || ExfiltrationReady &&&& StealthExitBlocked &&&& PlayersInCentral >= Mission_PlayersInGame",&n&t&tShowBlastTimer = "StartDetonation &&&& BlastTimer",&n&t&tExfiltrationDetonate = "StealthExitBlocked &&&& !BlastTimer",&n&t&t-- Determine if enemy spawns in the sewer can be used&n&t&tSewerSpawningEnabled = "BlastTimer <= 6",&n&t&tSewerPosition = "PlayersInSewerBack < PlayersInSewerFront &&&& 1 || PlayersInSewerBack > PlayersInSewerFront &&&& 2 || 3",&n&t&t-- Extra conditions for enemies not compromising gates&n&t&tCompromiseGracePeriod = "NetworkSweep >= 1 &&&& SweepGrace1 || NetworkSweep >= 2 &&&& SweepGrace2 || NetworkSweep >= 3 &&&& SweepGrace3",&n&t&tDontCompromiseMain = "SpawnAegis &&&& AegisRemaining",&n&t&t&n&t&t-- Combat stuff end&n&t&t&n&t&t-- Challenge helping&n&t&tEnteredStorage1 = "EnteredStorage1 || PlayersInStorageCloset1",&n&t&tEnteredStorage2 = "EnteredStorage2 || PlayersInStorageCloset2",&n&t&t&n&t&tEnteredSecurityCenter = "EnteredSecurityCenter || PlayersInSecurityCenter",&n&t&t&n&t&tGateTerminalEverCompromised = "GateTerminalEverCompromised || GateTerminalCompromised",&n&t&t&n&t&tAnyPCCompromised = "GateTerminalCompromised || DirectorPCCompromised",&n&t&tAnyServerCompromised = "MainServersCompromised || SecurityServersCompromised",&n&t&tAnyAPCompromised = "AP1Compromised || AP2Compromised || AP3Compromised || APNCompromised",&n&t&tAnyNSCompromised = "NS1Compromised || NS2Compromised || NS3Compromised",&n&t&t&n&t&tEnteredCloset = "EnteredCloset || PlayersInStorageCloset1 || PlayersInStorageCloset2 || PlayersInNS1Closet || PlayersInSecurityCloset1 || PlayersInSecurityCloset2",&n&t&t&n&t&tAbsenceNoticed = "AbsenceNoticed || !TakedownTimer1 &&&& TakedownCount >= 2",&n&t&t&n&t&tCompleteBeforeCombat = "CompleteBeforeCombat || !StealthExitBlocked &&&& ArtifactSearch5 &&&& (ServersScraped || ServersIsolated)",&n&t&t&n&t&tGateEverHackedButGarage = "GateEverHackedButGarage || N1Open || N2Open || N3Open || 12Open || 23Open",&n&t&tSilentFistFail = "SilentFistFail || GateEverHackedButGarage || RequestedN1Open &&&& !StartOpen1 || RequestedN2Open &&&& !StartOpen2 || RequestedN3Open &&&& !StartOpen3",&n&t&t&n&t&tEnemyGateEverOpened = "EnemyGateEverOpened || EnemyOpen12Delayed || EnemyOpen23Delayed || EnemyOpenN1Delayed || EnemyOpenN2Delayed || EnemyOpenN3Delayed || EnemyOpenGarageDelayed",&n&t&t&n&t&tGarageEverOpened = "GarageEverOpened || GarageOpen",&n&t&tGarageEverEntered = "GarageEverEntered || GarageEntered",&n&t&t&n&t&tHackingTabletEverHeld = "HackingTabletEverHeld || HackingTabletHeld",&n&t&t&n&t&tInitialHackingRisk = "InitialHackingRisk || Mission_ProgressToNextHackingDetection",&n&t&tHackRiskEverRaised = "HackRiskEverRaised || Mission_ProgressToNextHackingDetection < InitialHackingRisk",&n&t&t&n&t&tStealthPending = "StealthPending || ExfiltrationReady",&n&t&tCombatFail = "CombatFail || !Mission_AlarmRaised &&&& (GarageEntered || SecurityKeyHeld) || !StealthExitBlocked &&&& ArtifactSearch5 &&&& (ServersScraped || ServersIsolated)",&n&t&t&n&t&t-- Challenge states (these are mostly educated guesses as to what they mean)&n&t&t--Complete = 1, Green "COMPLETE", when challenge is complete and cannot fail or failure is something you must go out of your way to do&n&t&t--Pending = 2, Green "PENDING", when challenge condition is complete and mission objectives are fulfilled but can still fail before exfiltration&n&t&t--Failed = 4, Red "FAILED", when challenge condition is failed&n&t&t--InProgress = 6, Yellow "PENDING", when challenge condition is almost met or is in the process of being completed but can somewhat easily still be failed&n&t&t--Standard = 7, Normal default state&n&t&t--Invalid = 8, Red "INVALID", when the challenge condition is impossible to fulfill from the start for the current run&n&t&t&n&t&t-- Challenges&n&t&t-- Tier 1&n&t&tChallenge_FullPermission = "PermissionLevel >= 3 &&&& 1 || 7",&n&t&tChallenge_ProfessionallyCited = "SecurityPasswordSuccessfulSearch &&&& 1 || 7",&n&t&tChallenge_CompleteAccess = "(SecurityKeycardHeld || HighSecurityKeycardHeld) &&&& MasterKeyHeld &&&& 1 || 7",&n&t&tChallenge_HardwareVulnerability = "StorageBoxKilled &&&& 1 || 7",&n&t&tChallenge_PhysicalCopy = "ServersScraped &&&& 4 || !StealthExitBlocked &&&& ServerSecured &&&& 2 || ServerSecuredLoud &&&& 1 || 7",&n&t&tChallenge_DiverseArray = "AnyPCCompromised &&&& AnyServerCompromised &&&& AnyAPCompromised &&&& AnyNSCompromised &&&& 1 || 7",&n&t&t-- Tier 2&n&t&tChallenge_PrivateEye = "(EnteredSecurityCenter || Mission_AlarmRaised) &&&& 4 || StealthPending &&&& 2 || 7",&n&t&tChallenge_GateSwitch = "GateTerminalEverCompromised &&&& 4 || StealthPending &&&& 2 || 7",&n&t&tChallenge_ComputerAlert = "Mission_AlarmRaised &&&& 4 || (RadioDistraction || DirectorTamper || DirectorMessage || RadioMessage) &&&& 1 || 7",&n&t&tChallenge_NoSkeletons = "EnteredCloset &&&& 4 || StealthPending &&&& 2 || 7",&n&t&tChallenge_GoodRiddance = "(Mission_AlarmRaised || AbsenceNoticed) &&&& 4 || StealthPending &&&& 2 || 7",&n&t&tChallenge_SentPacking = "Mission_AlarmRaised &&&& 4 || GarageGuardsDown >= 2 &&&& 1 || 7",&n&t&tChallenge_InviteOnly = "(EnemyGateEverOpened || CombatFail) &&&& 4 || ExfiltrationDetonate &&&& 2 || 7",&n&t&tChallenge_SideDoor = "GarageEverOpened &&&& 4 || GarageEverEntered &&&& 2 || 7",&n&t&tChallenge_PersonalStyle = "(SecurityDisguiseUsed || Mission_AlarmRaised) &&&& 4 || StealthPending &&&& 2 || 7",&n&t&tChallenge_SafeBet = "HackRiskEverRaised &&&& 4 || StealthPending &&&& 2 || 7",&n&t&tChallenge_CourteousCriminal = "(Mission_AlarmRaised || ChallengeUtil_PropertyDamage) &&&& 4 || StealthPending &&&& 2 || 7",&n&t&t-- Tier 3&n&t&tChallenge_ExplosiveExit = "StealthExitBlocked &&&& !CompleteBeforeCombat &&&& 4 || !StealthExitBlocked &&&& CompleteBeforeCombat &&&& 6 || StealthExitBlocked &&&& CompleteBeforeCombat &&&& 1 || 7",&n&t&tChallenge_SilentFist = "(SilentFistFail || CombatFail) &&&& 4 || ExfiltrationDetonate &&&& 2 || 7",&n&t&tChallenge_SocialSecurity = "(HackingTabletEverHeld || Mission_AlarmRaised) &&&& 4 || StealthPending &&&& 2 || 7",&n&t},&n&t&n&t-- Apparently string templates don't work with the Hint field&n&tCustomMissionChallenges = {&n&t&tSideDoor = {&n&t&t&tName = "Challenge.SideDoorTransfer",&n&t&t&tDesc = "Challenge.Desc.SideDoorTransfer",&n&t&t&tHint = "Challenge.Hint.SideDoorTransfer",&n&t&t},&n&t&tInviteOnly = {&n&t&t&tName = "Challenge.InviteOnlyTransfer",&n&t&t&tDesc = "Challenge.Desc.InviteOnlyTransfer",&n&t&t&tHint = "Challenge.Hint.InviteOnlyTransfer",&n&t&t&tTags = {"CombatRequired"},&n&t&t},&n&t&tSocialSecurity = {&n&t&t&tName = "Challenge.SocialSecurityTransfer",&n&t&t&tDesc = "Challenge.Desc.SocialSecurityTransfer",&n&t&t&tHint = "Challenge.Hint.SocialSecurityTransfer",&n&t&t&tTags = {"StealthOnly"},&n&t&t},&n&t&tCompleteAccess = {&n&t&t&tName = "Challenge.CompleteAc