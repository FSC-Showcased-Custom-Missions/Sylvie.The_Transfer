:true},"Trespass":true,"MinorTrespass":{"ProSecurity":true}},"HeavilyRestricted":{"Enforce":{"Emp":true,"Sec":true},"Trespass":true,"EnforceMinor":{"Sec":true}},"Default":{"Trespass":false},"PrivateRestricted":{"Allow":{"ProSecurity":true},"Enforce":{"Emp":true,"Sec":true},"Trespass":true,"EnforceMinor":{"Sec":true}},"Private":"{OfficeAreaBluffed &&&& [PrivateBluffed] || [PrivateRestricted]}","WorkAreaBluffed":{"Trespass":false},"PrivateBluffed":{"Trespass":true,"Allow":{"ProSecurity":true},"Enforce":{"Emp":true,"Sec":true},"MinorTrespass":{"None":true},"EnforceMinor":{"Sec":true}},"WorkArea":"{OfficeAreaBluffed &&&& [WorkAreaBluffed] || [WorkAreaRestricted]}"},"DebugWatch":[],"CameraConfig":{"Main":{"OperatorTag":"CamOperator","RoomTag":"SecurityCenter"},"Garage":{"OperatorTag":"CamOperator","RoomTag":"SecurityCenter","RemoteMonitoring":"!Mission_AlarmRaised"}},"DialogueTree":{"GateAsk":{"CancelText":"UI.Nevermind"}},"Internals":{"BoxKey":"Variant_ChangeBoxKey &&&& [ClosetKey] || Mission_Difficulty >= 3 &&&& [ManagerOfficeKey] || [MasterKey]","SecurityNodesAlt0":"Variant_ShuffleInventories &&&& SecurityInv0 == 2","SecurityNodesAlt1":"Variant_ShuffleInventories &&&& SecurityInv1 ~= 2","SecurityNodesAlt2":"Variant_ShuffleInventories &&&& SecurityInv2 == 2","DirectorHeldCard":"Variant_ElevatedGarageCard &&&& [HighSecurityKeycard] || !Variant_DirectorBasicCard &&&& [SecurityKeycard] || [BasicKeycard]","DirectorHeldKey":"Variant_DirectorReducedKey &&&& [ManagerOfficeKey] || [MasterKey]"},"CustomStrings":{"Hacking.LockdownTerminal":"LOCKDOWN - Block Enemy Access to Terminal","Operator.Any.FailedArtifactSearch1":"Nope...","Action.EscalateKeycards":"Escalate Keycard Permissions","Hoax.PowerBoxQuestion2":"Killing power to all boxes in the area could reduce\nits strength and give you greater access","Challenge.Desc.InviteOnlyTransfer":"Complete combat without enemy units opening any gates","Hacking.Authorize":"Authorize","Challenge.Hint.GoodRiddanceTransfer":"Don't let any absences be noticed","Hacking.OpenGarage":"Open Garage Gate","Intel.TransferServersLocked":"Access to the servers is locked behind a security keycard reader and a USB key","Hoax.GetToCenter":"Now take the tome and get to the central chamber|\nIt's time for you to get out of there","UI.SecretServerRecord":"IRO ITEM RECORD - Liber Incantationum Adversariorum\n\nITEM ID: 1184599-305\n\nITEM DESCRIPTION: An untranslated leather-bound tome discovered on the outskirts of site CSP-4. Findings suggest that it was created during the late Gray Skies period of the Old Ages.\n\nLOCATION: This item is currently being held in IRO storage facility SD-427, located beneath the shore of Lake Simcoe in Ontario, Canada.\n\nSTATUS: Pending for transfer. For more details, consult today's TL sheet.\n\nREQUESTOR: Reputable historian Kalei Hale is currently requesting this item for the purpose of creating a translated form of this work.","Dialogue.HostageAskGate":"Go ask to open one of the gates","UI.RequiresHigherPermission":"Requires higher permission level","Hacking.DirectorsPC":"Director's Computer","Intel.TransferEscalatePanel":"A junction box near the security center can be rewired to escalate keycard permissions","Challenge.ProfessionallyCitedTransfer":"Professionally Cited","Challenge.Desc.FullPermissionTransfer":"Acquire a gate control permission level of 3","Intel.TransferComputerLure":"The director can be lured to their office if a message is planted on their computer","Operator.Any.LoudStart1":"Perfectly fine, everything's under control","Object.Security":"Security","StartingLocation.TransferBackEntrance.Desc":"Sneak down a back tunnel and enter through a fire escape in the security sector","Intel.TransferRadioDisrupt":"Worn radios can be disrupted through the facility's access points","Challenge.Hint.ExplosiveExitTransfer":"Use the sewer after finishing stealth","UI.RequiresOverride":"Requires gate security override","Hacking.RaisePermission":"Raise Permission","Challenge.GateSwitchTransfer":"Gate Switch","Intel.TransferFrontExit":"The front entrance can also be used as an exit","Tooltip.RequiresSkillElectricalEngineer2":"Requires Skill: Electrical Engineering 2","Objective.SearchLooseDocuments":"Search the loose documents","Challenge.Desc.PhysicalCopyTransfer":"Isolate the needed data and secure a server at an exit","Hacking.Lockdown":"Lockdown","Hint.TransferOfficeBluff":"[Social Engineering] Get caught trespassing in the office area","Hint.TransferSecuritySearch":"[Operative+] Search the security center terminal","Dialogue.HostageAskStorage":"Get the storage gate open","Hint.TransferMidAegis":"[Recruit, Operative] Complete half of our objective in combat","Objective.FindTome":"Find the tome","Intel.TransferStorageBoxes":"Killing all power boxes in Sector I will raise the permission level","Location.UtilityCloset":"utility closet","Objective.KeyItems":"Key Items","Hoax.TakedownSecondWarning":"The more guards they notice missing,\nthe faster and more seriously they're gonna take it","Dialogue.OpenOffice":"The director needs us","Intel.TransferDetonation":"Remote explosives will breach the wall between Sector N's back hall and the sewer","Challenge.Hint.CourteousCriminalTransfer":"No property damage","Intel.TransferUnknownLocation":"Which truck the tome is located in is unknown","Hoax.TakedownStop":"Good, just remember that radios are still an issue","UI.OpenStorage":"Open Storage","Intel.TransferTerminalLock":"This can be prevented by locking down the terminal","Intel.TransferStealStuff":"Steal server data and a tome from a government storage and research facility","Tag.MainObjective":"Main Objective","Hoax.PowerBoxQuestion1":"From what I've gathered, it could possibly be\ntied to a permission check system","Object.SectorIII":"Sector III","Hacking.OpenNToI":"Open Gate N-I","Action.RemindMe":"Remind Me","UI.RequiresTri1":"Requires Triangulation 1","Tag.Recruit":"Recruit","Objective.RaisingPermission":"Raising Permission","UI.EnemyHackedGate":"Enemies have hacked this gate open","Tag.SecurityTeam":"Security Team","StartingLocation.TransferFrontEntrance.Desc":"Pose as a government worker to make it through the front gate into the office sector","Intel.TransferBackEntryRewire":"This exit point can also be opened up by rewiring the door alarm","Challenge.Desc.SafeBetTransfer":"Complete the mission in stealth without gaining any hacking risk","Location.CentralRoom":"central room","Hoax.TRUArrive":"TRU is here, and it looks like they're in for the long haul|\nGet ready","Challenge.Hint.FullPermissionTransfer":"Get permission level 3","Objective.PowerBoxPermission":"Kill power boxes in storage","UI.DebugTakeOutSecurity":"Security center takedown","Intel.TransferNoticeMissing":"The director and security center will notice individual missing guards if they are not taken care of","Objective.LooseDocuments":"Loose Documents","Intel.TransferStorageUsb":"A USB key can be found in a network switch closet","Tag.Intimidation":"Intimidation","Hacking.TamperDirector":"TAMPER - Lure Director to Computer","Challenge.SideDoorTransfer":"Side Door","Intel.TransferCentralControl":"Gates can be opened through controls on the terminal in the central room","Challenge.Desc.GateSwitchTransfer":"Finish the mission without compromising the gate control terminal","Tag.ElectricalEngineering":"Electrical Engineering","Hint.TransferBackEntryRewire":"[Electrical Engineering] Investigate the back entrance without using it as an entry point","Intel.TransferEndGates":"Enemies will open the gates leading to Sector N if we try to exfiltrate","Intel.TransferEnemyAccess":"Enemy units may be able to access and utilize the facility's gate system","Hint.TransferGarageReader":"Access the garage through the keycard door","Intel.TransferEntryPoint":"The facility can be entered through any of the three outer sectors","Hacking.Scramble":"Scramble","Action.LureHer":"Lure Director to Her Office","Intel.TransferGarageEscalate":"Keycard permissions must be escalated to use the reader","File.SecurityFile":"As of today, access to the security server terminal must be greatly restricted due to an attempt at downloading a video game onto the terminal\n\nThe culprit will be justly punished with removal from the security staff team on account of inappropriate actions\n\nAuthorized personell will soon be notified of the updated terminal password","Operator.Any.UselessSearch3":"Nothing good...","Intel.TransferSecurityCenter":"A security center in Sector II watches over the cameras","Intel.TransferFrontEntry":"Sector III can be entered through the front entrance","Hacking.OpenIIToIII":"Open Gate II-III","Hint.TransferRadioLure":"Make a distraction using a radio","Hacking.ScrapeServers":"SCRAPE - Scrape Server Data","Operator.Any.LoudStart3":"Nothing we haven't dealt with before, we've got this","StartingLocation.TransferBackEntrance":"Back Entrance","Intel.TransferPermissionLevel":"Access to the facility's gate controls relies on a permission level system","Intel.TransferEnemyTerminal":"Enemy units can access the system through the gate control terminal","Intel.TransferCombat":"You may want to be aware of some things before entering combat in this mission","Dialogue.HostageRequestSecurity":"Hey could you open the security gate?","Hint.TransferEndGates":"Complete the mission objective in combat with enemies having gate control access","Password.Ruler48":"Ruler48","Objective.GateOverride":"Authorize the gate security override","Hint.TransferSecurityAuthorize":"Hack the security center terminal","Objective.RaisePermission":"Raise gate permission level","Tag.Operative":"Operative","Intel.TransferMidGates":"Enemies will open the gates between the outer sectors if half of our objective is complete","Challenge.Hint.SafeBetTransfer":"Don't generate hacking risk","Operator.Any.GatesCompromisedNoTablet":"We have access to their gate control system,\nbut we don't have a tablet to operate","Challenge.Desc.ComputerAlertTransfer":"Lure the director to the computer in their office","Hacking.Open13":"SEARCH - Find Secret File","Operator.Any.HostageOpenStorage":"Go ask the gate controller to open one of the gates|\nWe'll need the gate to the storage sector open","Hint.TransferNetworkSwitches":"Hack a network switch","Intel.TransferSecurityAuthorize":"A permission raise can be authorized from the security center terminal","File.MeetingNotes":"MEETING NOTES\n\n- Security center keycard reader has been updated to require a security keycard\n- A log of all recent and current transfers will be kept on the security servers\n- In case the gate operator is out for the day, authorization can be granted from the security center and the director's office\n- New security server access key","Location.SewerTunnel":"sewer tunnel","Challenge.PhysicalCopyTransfer":"Physical Copy","Object.SecurityDoor":"Security Door","Hacking.UnlockIIToIII":"UNLOCK - Open Security-Office Gate","Hoax.Intro3":"Alright, again, you're positive that you\nweren't hurt that bad by that fall?","Hint.TransferEscalatePanel":"[Electrical Engineering] Rewire the circuit box outside the security center","Hint.TransferComputerLure":"Hack the director's computer","Objective.MissingGuardsWarning":"Next noticed absence will raise alarm","Hacking.ScrambleRadios":"SCRAMBLE - Disable All Dropped Radios","Challenge.Desc.PersonalStyleTransfer":"Complete the mission in stealth without using disguises","Tag.Saw":"Saw","Intel.TransferDirectorAuthorize":"A permission raise can be authorized from the director's computer","Challenge.PrivateEyeTransfer":"Private Eye","Objective.FindSecurityKey":"Find a USB Key","Tag.Safecracking":"Safecracking","Hacking.UnlockIToII":"UNLOCK - Open Storage-Security Gate","Hacking.ArtifactLocation":"Tome Location","Item.UnobtainableKeycard":"???","Intel.TransferEnemySwitch":"Enemy units can also access the system through the facility's network switches","Challenge.Desc.ProfessionallyCitedTransfer":"Successfully search the loose documents across Sector II","Intel.TransferMidAegis":"Enemies will send in an Aegis unit after half of our objective is complete","Hacking.OverrideGates":"OVERRIDE - Override Gate Security","Object.PipeSymbol":"|","Intel.TransferLockerRoom":"A locker room with a clothing basket can be found in Sector II","Tag.SocialEngineering":"Social Engineering","Challenge.Desc.PrivateEyeTransfer":"Complete the mission without ever entering the security center","Action.Secure":"Secure","Object.Office":"Office","Dialogue.DirectorComputer":"Director, something popped up on your computer","Hoax.PermissionLevel":"Seems like you'll need a higher access level to open some gates|\nTry looking around the sectors for ways to raise your permission level","Hacking.SearchArtifactLocation":"SEARCH - Find Tome Location","Intel.TransferGarageReader":"The garage can be accessed through a high-security card reader","MissionDescription.TheTransfer":"Alright... I'm still not sure you're ready for this yet, but it's your choice. Today, you'll be infiltrating an IRO facility located under the shore of Lake Simcoe. Your primary target is a tome from the Old Ages that has been determined to be slated for transfer. The requestor of the tome is someone working for the Adversarialists, and if the Adversarialists were to get their hands on it, it would give them a major boost in their endeavors, so we can't let that happen. We have decent intel on security protocols and facility functions, but that's about it. Some remote explosives have been planted in a sewer adjacent to the facility in case things end in a firefight. Finally, if you weren't going to already, I would suggest that you bring a hacking tablet to this one. Good luck in there.","Intel.TransferOpenExit":"Entering this way opens up an additional exit point","Objective.CollectTheServer":"Collect the server","Hoax.TRUFirstAegis":"TRU is sending in an Aegis unit to your location|\nBe careful","Hoax.DetonationReady":"Alright, stand clear of the detonation site and be ready to\nmake a break for it once you've cleared out the enemy units","Hoax.ServersScrapedNeedArtifact":"Now you just need to find that tome and we'll be good to go","Hoax.GetToCenterStandalone":"Alright, get ready for exfiltration and go to the central room\n|You're taking the explosive way out","Hoax.BridgeAegis":"Look out, they've got a squad with an Aegis coming in|\nThey're trying to flank you before you can escape","Challenge.Desc.HardwareVulnerabilityTransfer":"Disable all power boxes in Sector I","Hoax.LoudStart3":"I'm seeing police activity in the area, and TRU is headed your way","Objective.StandClearOfBlast":"Stay clear of the back hall","Hacking.UnlockNToI":"UNLOCK - Open Central-Storage Gate","Challenge.SafeBetTransfer":"Safe Bet","Intel.TransferSectorDivide":"The facility is divided into sectors separated by gates","Operator.Any.LoudStart2":"We can handle them, don't worry","Operator.Any.HostageOpenSecurity":"Go ask the gate controller to open one of the gates|\nWe'll need the gate to the security sector open","Intel.TransferNetworkSwitches":"Gates can also be opened through the facility's network switches","Hacking.UnlockNToIII":"UNLOCK - Open Central-Office Gate","Hoax.LoudStart1":"Police scanners are going off and TRU is being called in,\neverything okay in there?","Hacking.Scrape":"Scrape","Notify.TooManyMissing":"Too many guards noticed missing","Operator.Any.OpenSecurity":"We need the gate to security open|\nThe security center called us in for a private meeting","Challenge.Desc.SideDoorTransfer":"Complete the mission without hacking the garage gate open","Operator.Any.JunctionExamined1":"Looks like this junction box is tied to the\nfacility's keycard readers","Operator.Any.TakedownStop":"Security center and director have been taken care of","File.PasswordLog":"SECURITY TERMINAL ACTION HISTORY\n\n07:01:23 TERMINAL ACCESSED\n07:02:05 ROUTINE SCAN OF SERVERS\n07:06:53 TERMINAL SHUTDOWN\n11:34:42 TERMINAL ACCESSED\n11:35:36 UNAUTHORIZED FILE DOWNLOAD ATTEMPT - FILENAME: RobloxPlayerInstaller.exe\n14:45:23 LEVEL OF AUTHORIZATION NEEDED FOR GATE CONTROL TEMPORARILY RAISED\n14:47:49 1 FILE DELETED\n14:48:57 TERMINAL SHUTDOWN WITH PASSWORD UPDATE - NEW PASSWORD","Intel.TransferRadioLure":"The director can be lured to their office if notified on the radio","Intel.TransferSectorNOpen":"A gate leading to Sector N will be open from one of the sectors entered through","Hoax.TakedownFirstWarning":"Be careful with taking out guards. The security center and\nthe director will probably get suspicious if you do","Intel.TransferSecurityTeam":"A professional security team is present on-site","Operator.Any.DirectorLureNotSuspicious":"Director, we got a notification that there's a message on your office computer|\nSomething urgent about a request for an untranslated tome","UI.OpenSecurity":"Open Security","Operator.Any.DirectorLure":"Director, we're seeing something come up on your computer|\nYou might want to have a look in your office","Location.SecuritySector":"security sector","Operator.Any.HostageOpenOffice":"Go ask the gate controller to open one of the gates|\nWe'll need the gate to the office sector open","Hoax.CanExfiltrateStealth":"That should be all, now|\nGet back to wherever you came from and get out of there","Hint.TransferSafeUsb":"Open the safe in the security center","Hoax.ServersScraped":"Alright, I can see the data coming through now|\nThis could prove to be very useful for the future","Hoax.LoudStart2":"Radio activity just spiked, looks like they're calling in TRU","Tag.Combat":"Combat","Hoax.ArtifactFound":"Yep, that's the one|\nIt might not be as flashy as a sword, but it may be\nof equal importance to the Adversarialists","Operator.Any.OpenOffice":"We need the gate to the office open|\nThe director needs us for something","Operator.Any.OpenStorage":"We need the gate to storage open|\nWe're going to be moving some boxes soon","Hoax.Intro2":"Our medics say you won't be ready for operations\nuntil a few weeks from now","Challenge.Hint.HardwareVulnerabilityTransfer":"Disable Sector I power boxes","Name.Security":"Security","Dialogue.OfficeBluff":"I see. The schedule must have changed since I last checked, then|\nGo ahead","Hacking.ServerData":"Server Data","Hoax.GatesCompromised":"Okay, now on to the next stage of the operation","Operator.Any.PowerBoxQuestion":"Hey Hoax, any idea what this power box could be for?","Intel.TransferSecuritySearch":"The correct truck can be identified by hacking the security center terminal","Hoax.ServersScrapedFoundInfo":"There's an archive lookup code here for some kind of document\nthat has the location of the tome, I'll send it to you now","Hint.TransferDirectorAuthorize":"Hack the director's computer","Action.Search":"Search","Hoax.ServersIsolated":"Remember that you need to secure the server at an\nexit point before you can get out of there","MissionTitle.TheTransfer":"The Transfer","Operator.Any.ServersIsolated":"Data has been isolated","Hacking.Disrupt":"Disruption","Hacking.AuthorizePermissionRaise":"AUTHORIZE - Raise Permission Level","Operator.Any.ServersScraped":"Servers have been scraped","Hoax.ServersAccessed":"Good, now you have two options|\nYou can scrape the servers and get the data directly,\nor you can isolate what we need to one server and take it","Operator.Any.ServersAccessed":"In the server room","Challenge.Hint.PhysicalCopyTransfer":"Secure a physical server","Tag.Legend":"Legend","UI.SecurityServerPassword":"Security Server Password","Challenge.Hint.CompleteAccessTransfer":"Get a master key and security card","Hacking.Terminal":"Terminal","UI.RequiresTri2":"Requires Triangulation 2","Challenge.Desc.SentPackingTransfer":"Incapacitate both guards patrolling the garage","Intel.TransferOfficeBluff":"The office area of Sector III can be bluffed through","Operator.Any.HostageOpenGate":"Go ask the gate controller to open one of the gates","Location.Garage":"garage","Operator.Any.UselessSearch2":"Useless...","Operator.Any.UselessSearch1":"Nope...","StartingLocationTitle.EntryPoint":"Entry Point","ItemDesc.Tome":"An ancient leather-bound tome from the Old Ages. A strange octagonal shape on a gold seal can be seen on its front. May contain information on dangerous procedures","Objective.Exfiltrate":"Exfiltrate","Object.GateControl":"Gate Control","Hint.TransferArchives":"[Operative+] Search the archives","Notify.InterrogationGaveOfficeSafeCode":"Interrogation gave safe code","StartingLocation.TransferFrontEntrance":"Front Entrance","Operator.Any.FailedArtifactSearch2":"Not in this one...","Operator.Any.LocationFound":"Found which truck the tome's being kept in","Hoax.GatesCompromisedNoTablet":"Bit of a last-ditch effort, but there might be\none somewhere in storage or a closet","Operator.Any.GatesCompromised":"We've compromised their gate control system","Operator.Any.Intro3":"Absolutely. This mission is too important to just let go","Password.Dragon50":"Dragon50","Hacking.OpenNToIII":"Open Gate N-III","Object.SectorN":"Sector N","Hacking.CardCredentials":"Card Credentials","Hoax.Intro1":"You're still certain you want to do this?","Object.SectorIIFull":"Sector II: Security","Location.DirectorsOffice":"director's office","Speaker.Hoax":"Hoax","Dialogue.GovtInspection":"I'm here for an inspection","Dialogue.HostageRequestOffice":"Hey could you open the office gate?","Dialogue.HostageRequestStorage":"Hey could you open the storage gate?","Dialogue.HostageAskOffice":"Get the office gate open","Hacking.OpenNToII":"Open Gate N-II","Location.ServerRoom":"server room","Challenge.CompleteAccessTransfer":"Complete Access","Dialogue.HostageAskSecurity":"Get the security gate open","Dialogue.OpenGate":"Could you open one of the gates?","Dialogue.OpenSecurity":"The security center called us in","Dialogue.OpenStorage":"We need to move some boxes","Dialogue.DirectorMessage":"Director, there's a message on your computer","Intel.TransferIsolatedGates":"If no gates in your sector are open, enemies will try to open one of them","Object.Storage":"Storage","Challenge.Hint.NoSkeletonsTransfer":"Don't enter closets","Action.EnableExitPoint":"Enable Exit Point","Intel.TransferNetworkSweep":"Enemy access to the network can also be removed from the terminal","Name.Employee":"Employee","Challenge.InviteOnlyTransfer":"Invite Only","Password.Smile45":"Smile45","Password.Story30":"Story30","StartingLocation.TransferVentilationShaft":"Ventilation Shaft","Password.Detective26":"Detective26","Objective.FindTablet":"Find a hacking tablet","Intel.TransferBackEntry":"Sector II can be entered through a fire escape","Password.Clover21":"Clover21","ItemDesc.UnobtainableKeycard":"What the... How did you... Huh??","Password.Dance13":"Dance13","Location.InThe":"in the","ItemDesc.ClosetKey":"Access key for storage and utility closets","Challenge.SilentFistTransfer":"Silent Fist","UI.OpenGate":"Open Gate","Hint.TransferSafeCard":"[Safecracking] Open the safe in the director's office","Intel.TransferSafeCard":"A high security keycard can be found in a safe in the director's office","Hint.TransferRadioDisrupt":"Hack an access point","Objective.EnterGarage":"Enter the garage","Challenge.Desc.NoSkeletonsTransfer":"Finish the mission without ever entering a closet","Hint.TransferMidGates":"Complete half of our objective in combat with enemies having gate control access","Challenge.Hint.DiverseArrayTransfer":"Access 4 unique network node types","Intel.TransferVentEntry":"Sector I can be entered through an air vent","Item.ClosetKey":"Closet Key","Item.Tome":"Tome","Objective.ScrapeServers":"Scrape server data","Notify.SuspiciousDistraction":"Suspicious distraction","Intel.TransferUnitBoost":"The more ways enemies have of accessing you, the more units they will bring in at once","Operator.Any.JunctionExamined2":"If I can rewire it, I might be able to\nlower the restrictions on the readers","Intel.TransferDirectorInterrogate":"The director can be interrogated for the safe code","No